### Anti-Exploit Protection
```lua
-- ❌ DO NOT TRUST THE CLIENT
-- Client says: "I dealt 999999 damage"

-- ✅ SERVER-SIDE VALIDATION
local MAX_DAMAGE = 100
local function dealDamage(attacker: Player, target: Player, damage: number)
    -- Checks
    if damage > MAX_DAMAGE or damage <= 0 then
        warn("Suspicious damage from", attacker.Name)
        return
    end

    -- Check distance between players
    local distance = (attacker.Character.HumanoidRootPart.Position - target.Character.HumanoidRootPart.Position).Magnitude
    if distance > 50 then
        warn("Too far for attack:", attacker.Name)
        return
    end

    -- Deal damage
    target.Character.Humanoid:TakeDamage(damage)
end
```

## Special Features

### Procedural Generation
```lua
-- Generate random island from blocks
local function generateIsland(size: number): Model
    local island = Instance.new("Model")
    island.Name = "ProceduralIsland"

    for x = 1, size do
        for z = 1, size do
            local height = math.noise(x / 10, z / 10) * 20 + 10

            for y = 1, height do
                local part = Instance.new("Part")
                part.Size = Vector3.new(4, 4, 4)
                part.Position = Vector3.new(x * 4, y * 4, z * 4)
                part.Anchored = true
                part.Parent = island
            end
        end
    end

    return island
end
```

### State Machine
```lua
local EnemyAI = {}
EnemyAI.__index = EnemyAI

function EnemyAI.new(npc: Model)
    local self = setmetatable({}, EnemyAI)
    self.NPC = npc
    self.State = "Idle"
    self.Target = nil
    return self
end

function EnemyAI:Update(deltaTime: number)
    if self.State == "Idle" then
        self:SearchForTarget()
    elseif self.State == "Chasing" then
        self:ChaseTarget()
    elseif self.State == "Attacking" then
        self:AttackTarget()
    end
end

function EnemyAI:SearchForTarget()
    -- Find nearest player
    local nearestPlayer = self:FindNearestPlayer(50)
    if nearestPlayer then
        self.Target = nearestPlayer
        self.State = "Chasing"
    end
end

return EnemyAI
```

